#. module: easytech_check_matrix
#: model:ir.module.module,shortdesc:0
msgid "EasyTech Matrix Check"
msgstr "Cheque matricial EasyTech"

#. module: easytech_check_matrix
#: model:ir.module.module,summary:0
msgid "Matrix check printing and preview on preprinted forms (multi-bank)"
msgstr "Impresión y vista previa de cheques matriciales en formularios preimpresos (multi-banco)"

#. module: easytech_check_matrix
#: model:ir.module.module,description:0
msgid ""
"\n"
"EasyTech matrix check engine for Odoo Community.\n"
"\n"
"- Based on account.payment.\n"
"- Matrix check button on payments.\n"
"- Batch action from payment list.\n"
"- Single or batch preview.\n"
"- Printing with status and checkbook numbering.\n"
"- Per-bank templates with offsets.\n"
msgstr ""
"\n"
"Motor de cheque matricial EasyTech para Odoo Community.\n"
"\n"
"- Basado en account.payment.\n"
"- Botón de cheque matricial en pagos.\n"
"- Acción por lotes desde la lista de pagos.\n"
"- Vista previa individual o por lotes.\n"
"- Impresión con estado y numeración por chequera.\n"
"- Plantillas por banco con desplazamientos.\n"

