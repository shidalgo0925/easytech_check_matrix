<odoo>
    <record id="group_easytech_check_user" model="res.groups">
        <field name="name">Usuario Cheque Matricial EasyTech</field>
        <field name="category_id" ref="base.module_category_accounting_accounting"/>
        <field name="implied_ids" eval="[(4, ref('account.group_account_invoice'))]"/>
    </record>

    <record id="group_easytech_check_manager" model="res.groups">
        <field name="name">Gestor Cheque Matricial EasyTech</field>
        <field name="category_id" ref="base.module_category_accounting_accounting"/>
        <field name="implied_ids" eval="[(4, ref('group_easytech_check_user')), (4, ref('account.group_account_manager'))]"/>
    </record>
</odoo>
