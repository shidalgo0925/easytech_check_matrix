<odoo>
    <record id="view_account_journal_form_easytech_matrix" model="ir.ui.view">
        <field name="name">account.journal.form.easytech.matrix</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[.//field[@name='bank_account_id']]" position="after">
                <group string="EasyTech matrix check">
                    <field name="easytech_use_check_matrix"/>
                    <field name="easytech_checkbook_id" invisible="not easytech_use_check_matrix"/>
                    <field name="easytech_check_template_id" invisible="not easytech_use_check_matrix"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
