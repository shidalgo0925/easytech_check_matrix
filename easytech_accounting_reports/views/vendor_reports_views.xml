<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Libro mayor proveedores -->
    <record id="view_easytech_vendor_ledger_line_tree" model="ir.ui.view">
        <field name="name">easytech.vendor.ledger.line.tree</field>
        <field name="model">easytech.vendor.ledger.line</field>
        <field name="arch" type="xml">
            <list create="0" delete="0" decoration-info="is_opening">
                <field name="partner_id"/>
                <field name="date"/>
                <field name="is_opening" column_invisible="1"/>
                <field name="ref"/>
                <field name="journal_id" optional="show"/>
                <field name="label"/>
                <field name="debit" sum="Total debe"/>
                <field name="credit" sum="Total haber"/>
                <field name="balance" sum="Total"/>
                <field name="cumulative_balance"/>
                <field name="company_currency_id" column_invisible="1"/>
                <field name="move_id" column_invisible="1"/>
                <field name="move_line_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_easytech_vendor_ledger_wizard_form" model="ir.ui.view">
        <field name="name">easytech.vendor.ledger.wizard.form</field>
        <field name="model">easytech.vendor.ledger.wizard</field>
        <field name="arch" type="xml">
            <form string="Libro mayor de proveedores">
                <group>
                    <group>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                        <field name="partner_ids" widget="many2many_tags" placeholder="Todos los proveedores con movimiento"/>
                    </group>
                </group>
                <div class="oe_button_box">
                    <button name="action_load_lines" type="object" string="Cargar movimientos" class="btn-primary"/>
                    <button name="action_export_csv" type="object" string="Exportar CSV" class="btn-secondary"/>
                    <button name="action_export_xlsx" type="object" string="Exportar Excel" class="btn-secondary"/>
                </div>
                <field name="line_ids" nolabel="1"/>
            </form>
        </field>
    </record>

    <record id="action_easytech_vendor_ledger_wizard" model="ir.actions.act_window">
        <field name="name">Libro mayor de proveedores</field>
        <field name="res_model">easytech.vendor.ledger.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_easytech_vendor_ledger"
        name="Libro mayor de proveedores"
        parent="easytech_accounting_reports.menu_easytech_payables_root"
        action="action_easytech_vendor_ledger_wizard"
        sequence="40"
    />

    <!-- Antigüedad AP -->
    <record id="view_easytech_ap_aging_line_tree" model="ir.ui.view">
        <field name="name">easytech.ap.aging.line.tree</field>
        <field name="model">easytech.ap.aging.line</field>
        <field name="arch" type="xml">
            <list create="0" delete="0" decoration-bf="is_partner_total">
                <field name="is_partner_total" column_invisible="1"/>
                <field name="partner_id"/>
                <field name="move_id" optional="show" column_invisible="is_partner_total"/>
                <field name="invoice_date" optional="hide" column_invisible="is_partner_total"/>
                <field name="invoice_date_due" optional="hide" column_invisible="is_partner_total"/>
                <field name="days_overdue" column_invisible="is_partner_total"/>
                <field name="bucket" optional="hide" column_invisible="is_partner_total"/>
                <field name="currency_id" string="Moneda doc." optional="hide" column_invisible="is_partner_total"/>
                <field name="company_currency_id" column_invisible="1"/>
                <field name="amount_residual" string="Saldo doc." sum="Total doc." optional="show" column_invisible="is_partner_total"/>
                <field name="amount_residual_company" string="Saldo comp." sum="Total comp."/>
                <field name="amount_current" string="Corriente" sum="C" optional="show" column_invisible="is_partner_total"/>
                <field name="amount_1_30" string="1-30" sum="1-30" optional="show" column_invisible="is_partner_total"/>
                <field name="amount_31_60" string="31-60" sum="31-60" optional="show" column_invisible="is_partner_total"/>
                <field name="amount_61_90" string="61-90" sum="61-90" optional="show" column_invisible="is_partner_total"/>
                <field name="amount_90_plus" string="+90" sum="+90" optional="show" column_invisible="is_partner_total"/>
                <field name="amount_current_company" string="Corriente (comp.)" sum="C (comp.)" optional="show"/>
                <field name="amount_1_30_company" string="1-30 (comp.)" sum="1-30 (c.)" optional="show"/>
                <field name="amount_31_60_company" string="31-60 (comp.)" sum="31-60 (c.)" optional="show"/>
                <field name="amount_61_90_company" string="61-90 (comp.)" sum="61-90 (c.)" optional="show"/>
                <field name="amount_90_plus_company" string="+90 (comp.)" sum="+90 (c.)" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_easytech_ap_aging_wizard_form" model="ir.ui.view">
        <field name="name">easytech.ap.aging.wizard.form</field>
        <field name="model">easytech.ap.aging.wizard</field>
        <field name="arch" type="xml">
            <form string="Antigüedad de saldos proveedores">
                <group>
                    <group>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="as_of_date"/>
                        <field name="line_mode"/>
                    </group>
                    <group>
                        <field name="partner_ids" widget="many2many_tags" placeholder="Todos los proveedores con saldo"/>
                    </group>
                </group>
                <div class="oe_button_box">
                    <button name="action_load_lines" type="object" string="Cargar antigüedad" class="btn-primary"/>
                    <button name="action_export_csv" type="object" string="Exportar CSV" class="btn-secondary"/>
                    <button name="action_export_xlsx" type="object" string="Exportar Excel" class="btn-secondary"/>
                </div>
                <field name="line_ids" nolabel="1"/>
            </form>
        </field>
    </record>

    <record id="action_easytech_ap_aging_wizard" model="ir.actions.act_window">
        <field name="name">Antigüedad de saldos proveedores</field>
        <field name="res_model">easytech.ap.aging.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_easytech_ap_aging"
        name="Antigüedad proveedores"
        parent="easytech_accounting_reports.menu_easytech_payables_root"
        action="action_easytech_ap_aging_wizard"
        sequence="50"
    />
</odoo>
