<odoo>
    <record id="view_easytech_checkbook_tree" model="ir.ui.view">
        <field name="name">easytech.checkbook.tree</field>
        <field name="model">easytech.checkbook</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="journal_id"/>
                <field name="number_start"/>
                <field name="number_end"/>
                <field name="current_number"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_easytech_checkbook_form" model="ir.ui.view">
        <field name="name">easytech.checkbook.form</field>
        <field name="model">easytech.checkbook</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="company_id"/>
                        <field name="journal_id"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="number_start"/>
                        <field name="number_end"/>
                        <field name="current_number"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_easytech_checkbook" model="ir.actions.act_window">
        <field name="name">Chequeras</field>
        <field name="res_model">easytech.checkbook</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_easytech_checkbook"
              name="Chequeras"
              parent="account.menu_finance_configuration"
              action="action_easytech_checkbook"
              sequence="91"
              groups="easytech_check_matrix.group_easytech_check_manager"/>
</odoo>
